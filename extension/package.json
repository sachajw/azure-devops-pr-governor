{
  "name": "pr-scheduler-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Azure DevOps extension for PR Scheduler policy management",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack serve --mode development",
    "clean": "rm -rf dist",
